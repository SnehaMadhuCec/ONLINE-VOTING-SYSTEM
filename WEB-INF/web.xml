<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Online Voting System</display-name>

    <!-- Admin Login Servlet -->
    <servlet>
        <servlet-name>AdminLoginServlet</servlet-name>
        <servlet-class>AdminLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminLoginServlet</servlet-name>
        <url-pattern>/adminlogin</url-pattern>
    </servlet-mapping>

    <!-- Voter Login Servlet -->
    <servlet>
        <servlet-name>VoterLoginServlet</servlet-name>
        <servlet-class>VoterLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VoterLoginServlet</servlet-name>
        <url-pattern>/voterlogin</url-pattern>
    </servlet-mapping>

    <!-- Voter Registration Servlet -->
    <servlet>
        <servlet-name>VoterRegistrationServlet</servlet-name>
        <servlet-class>VoterRegistrationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VoterRegistrationServlet</servlet-name>
        <url-pattern>/registration</url-pattern>
    </servlet-mapping>

    <!-- Vote Servlet -->
    <servlet>
        <servlet-name>VoteServlet</servlet-name>
        <servlet-class>VoteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VoteServlet</servlet-name>
        <url-pattern>/vote</url-pattern>
    </servlet-mapping>

    <!-- Result Servlet -->
    <servlet>
        <servlet-name>ResultServlet</servlet-name>
        <servlet-class>ResultServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResultServlet</servlet-name>
        <url-pattern>/result</url-pattern>
    </servlet-mapping>

    <!-- Admin Dashboard Servlet -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admindash</url-pattern>
    </servlet-mapping>

    <!-- Candidate Management Servlet -->
    <servlet>
        <servlet-name>CandidateServlet</servlet-name>
        <servlet-class>CandidateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CandidateServlet</servlet-name>
        <url-pattern>/candidates</url-pattern>
    </servlet-mapping>

    <!-- Vote Display JSP -->
    <servlet>
        <servlet-name>VoteDisplay</servlet-name>
        <jsp-file>/votedisplay.jsp</jsp-file>
    </servlet>
    <servlet-mapping>
        <servlet-name>VoteDisplay</servlet-name>
        <url-pattern>/votedisplay</url-pattern>
    </servlet-mapping>

    <!-- Welcome page (only index.jsp shown directly) -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
